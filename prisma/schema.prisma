// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model shop {
  id                      Int       @id @default(autoincrement())
  shop                    String    @unique(map: "Shop_shop_key")
  accessToken             String?
  installed               Boolean   @default(false)
  status                  String?   @default("installed") @db.VarChar(32)
  ownerName               String?   @db.VarChar(255)
  email                   String?   @db.VarChar(320)
  contactEmail            String?   @db.VarChar(320)
  name                    String?   @db.VarChar(255)
  country                 String?   @db.VarChar(100)
  city                    String?   @db.VarChar(100)
  currency                String?   @db.VarChar(10)
  phone                   String?   @db.VarChar(50)
  primaryDomain           String?   @db.VarChar(255)
  plan                    String?   @db.VarChar(100)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  onboardedAt             DateTime?
  uninstalledAt           DateTime?
  announcementEmailSentAt DateTime?
}

model Task {
  id                   Int       @id @default(autoincrement())
  shop                 String    @db.VarChar(255)
  status               String    @default("draft") @db.VarChar(32)
  applyChangesTo       String    @default("products") @db.VarChar(32)
  applyToFixedPrices   Boolean   @default(false)
  selectedMarkets      Json?
  priceChange          Json?
  compareAtPriceChange Json?
  costPerItemChange    Json?
  applyScope           String    @default("whole_store") @db.VarChar(64)
  excludeScope         String    @default("nothing") @db.VarChar(64)
  discountedScope      String    @default("nothing") @db.VarChar(64)
  applyResources       Json?
  excludeResources     Json?
  configuration        Json?
  executionSummary     Json?
  autoReapply          Boolean   @default(false)
  autoReapplyChanges   Boolean   @default(false)
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  auditLogs            TaskAuditLog[]

  @@index([shop])
  @@index([status])
  @@map("task")
}

model TaskAuditLog {
  id            Int      @id @default(autoincrement())
  taskId        Int
  shop          String   @db.VarChar(255)
  productId     String?  @db.VarChar(255)
  variantId     String?  @db.VarChar(255)
  previousPrice String?  @db.VarChar(32)
  newPrice      String?  @db.VarChar(32)
  action        String   @db.VarChar(32)
  skipReason    String?  @db.VarChar(500)
  createdAt     DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([shop])
  @@index([action])
  @@map("task_audit_log")
}

model Sale {
  id                    Int       @id @default(autoincrement())
  shop                  String    @db.VarChar(255)
  title                 String    @db.VarChar(255)
  status                String    @default("draft") @db.VarChar(32)
  changeType            String    @default("products") @db.VarChar(32)
  applyToFixedPrices    Boolean   @default(false)
  markets               Json?
  priceChange           Json?
  compareAtPriceChange  Json?
  applyScope            String    @default("whole_store") @db.VarChar(64)
  excludeScope          String    @default("nothing") @db.VarChar(64)
  discountedScope       String    @default("nothing") @db.VarChar(64)
  applyResources        Json?
  excludeResources      Json?
  tagRules              Json?
  schedule              Json?
  configuration         Json?
  executionSummary      Json?
  startAt               DateTime?
  endAt                 DateTime?
  addTagsEnabled        Boolean   @default(false)
  removeTagsEnabled     Boolean   @default(false)
  trackConditionChanges Boolean   @default(false)
  autoReapplyChanges    Boolean   @default(false)
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([shop])
  @@index([status])
  @@index([startAt])
  @@map("sale")
}
